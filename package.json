{
  "name": "@thehonker/diffsurfer",
  "version": "1.1.1",
  "description": "diffsurfer",
  "keywords": [
    "diffsurfer"
  ],
  "author": "Edwin Pers <pers.edwin@gmail.com>",
  "main": "dist/main.mjs",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "npx eslint src/",
    "build": "npm run test && npx tsc && npm run copy-assets",
    "copy-assets": "node -e \"const os=require('os'); const {execSync}=require('child_process'); const path=require('path'); const scriptPath=path.join('./scripts', os.platform()==='win32'?'copy-assets.bat':'copy-assets.sh'); execSync(scriptPath,{stdio:'inherit'})\"",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "server": "electron . --server",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "bump": "./scripts/bump-version.sh"
  },
  "build": {
    "appId": "com.thehonker.diffsurfer",
    "productName": "Diffsurfer",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/@types/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "src/assets/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "src/assets/icon.ico"
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "icon": "src/assets/icon.png"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.19.130",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "simple-git": "^3.33.0",
    "winston": "^3.19.0"
  }
}
